# ==========================================
# OpenVPN + SOCKS5 Proxy with DDNS Auto-Reconnect
# ==========================================

# DDNS Hostname (required)
# The DDNS hostname to monitor for IP changes
# Example: vpn.example.com
DDNS_HOSTNAME=

# GitHub Container Registry image name (required)
# Format: ghcr.io/USERNAME/REPO:TAG
# Example: ghcr.io/johndoe/openvpn-ddns-proxy:main
IMAGE_NAME=

# OpenVPN configuration directory
# This directory should contain config.ovpn and all certificate/key files
VPN_CONFIG_DIR=./vpn

# DDNS check interval in seconds
# How often to check if the DDNS IP has changed
DDNS_CHECK_INTERVAL=60

# SOCKS5 proxy port
SOCKS_PORT=1080

# OpenVPN remote server port (optional, extracted from config.ovpn if not set)
REMOTE_PORT=1194

# OpenVPN protocol (udp or tcp, optional, extracted from config.ovpn if not set)
REMOTE_PROTO=udp

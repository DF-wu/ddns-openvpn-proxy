# Timezone used by the runtime logs.
TZ=UTC

# Directory mounted to /config in the upstream image.
# Put your .ovpn file and any referenced cert/key/auth files under ./config/openvpn/.
OPENVPN_CONFIG_DIR=./config

# Optional username/password when your provider or server expects env-driven auth.
OPENVPN_USER=
OPENVPN_PASSWORD=

# SOCKS5 listener configuration.
SOCKS5_PORT=1080
SOCKS5_USER=socks5
SOCKS5_PASSWORD=change-me

# Your host or LAN CIDR so you can reach the SOCKS5 port through the upstream firewall.
# Use scripts/detect-lan-network.sh as a starting point.
LAN_NETWORK=192.168.1.0/24

# DNS resolvers used inside the container.
NAME_SERVERS=1.1.1.1,1.0.0.1

# Runtime identity settings expected by the upstream image.
PUID=0
PGID=0
UMASK=022

# Tested upstream image reference.
# Keep this pinned unless you intentionally re-validate a newer image.
VPN_IMAGE=binhex/arch-privoxyvpn@sha256:75c98f92941ac0fd6d2c8533a51e3482472ed2651954836091e0e95148996469
